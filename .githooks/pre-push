#!/usr/bin/env bash
# Artist Hub — pre-push design gate.
# Secret/PII scan + design-rule audit + visual-regression + performance budget.
# Blocks the push on any secret, defect, visual change, or over-budget perf.
# One-time activation:  git config core.hooksPath .githooks
# Bypass for one push:  git push --no-verify
set -uo pipefail

echo "▶  Secret / PII scan…"
if ! npm --prefix tools run --silent scan; then
  echo "✗  Secret found in deployed output — push blocked. Remove it, or override:  git push --no-verify"
  exit 1
fi

if [ ! -d tools/node_modules/playwright ]; then
  echo "⚠  Playwright not installed — skipping audit/visual/perf (the scan above still ran)."
  echo "   Set up once:  npm --prefix tools install && tools/node_modules/.bin/playwright install chromium"
  exit 0
fi

echo "▶  Design-rule audit…"
if ! npm --prefix tools run --silent audit; then
  echo "✗  Audit failed — push blocked. Fix the defects above, or override:  git push --no-verify"
  exit 1
fi

echo "▶  Visual-regression…"
if ! npm --prefix tools run --silent visual; then
  echo "✗  Visual changes detected — push blocked. Review tools/diffs/, then accept with:"
  echo "     npm --prefix tools run visual -- --update   (and commit the updated baselines)"
  echo "   …or override:  git push --no-verify"
  exit 1
fi

echo "▶  Performance budget…"
if ! npm --prefix tools run --silent perf; then
  echo "✗  Performance over budget — push blocked. See the table above, or override:  git push --no-verify"
  exit 1
fi

echo "✓  Scan + audit + visual + perf passed — pushing."
exit 0
